{
  "name": "pdf-microservice",
  "version": "1.0.0",
  "description": "PDF generation microservice using Puppeteer, Fastify, and S3",
  "license": "MIT",
  "main": "dist/local.js",
  "scripts": {
    "build": "esbuild src/local.ts src/lambda.ts --bundle --platform=node --target=node24 --outdir=dist --external:@sparticuz/chromium --external:pino --external:pino-pretty --format=cjs",
    "dev": "node --watch --import tsx src/local.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src test",
    "test": "vitest run",
    "test:cov": "vitest run --coverage",
    "smoke": "bash scripts/smoke-test.sh"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.600.0",
    "@aws-sdk/s3-request-presigner": "^3.600.0",
    "@fastify/aws-lambda": "^6.4.0",
    "@fastify/sensible": "^6.0.4",
    "@sparticuz/chromium": "^143.0.4",
    "fastify": "^5.8.4",
    "fastify-plugin": "^5.1.0",
    "pdf-lib": "^1.17.1",
    "pino-pretty": "^13.1.3",
    "puppeteer-core": "^24.40.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/aws-lambda": "^8.10.0",
    "@types/node": "^24.0.0",
    "@vitest/coverage-v8": "^4.1.2",
    "esbuild": "^0.27.4",
    "eslint": "^10.1.0",
    "tsx": "^4.0.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.0.0",
    "vitest": "^4.1.2"
  }
}
