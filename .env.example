# Required
S3_BUCKET=my-pdf-bucket
AWS_REGION=us-central-1

# Production only (not needed with Lambda execution role)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# Local development only (MinIO)
AWS_ENDPOINT_URL=http://minio:9000
AWS_PUBLIC_ENDPOINT_URL=http://localhost:9000
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin

# Optional
SIGNED_URL_EXPIRY_SECONDS=3600
LOG_LEVEL=info

# API authentication (recommended in production, minimum 32 characters)
# API_KEY=your-secret-key-minimum-32-chars
